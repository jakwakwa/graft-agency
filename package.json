{
  "name": "graft-today-agency",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "install-deps": "bun install",
    "delete-bun-tests": "rm tests/inngest/stitch-bypass-stress.test.ts tests/inngest/stitch-temp-disable-variations.test.ts",
    "dev:tunnel": "bun scripts/pinggy.sh",
    "inngest:dev": "bun scripts/inngest-dev-serve.ts",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "test": ". .env && DATABASE_URL=$TEST_DATABASE_URL vitest run",
    "test:watch": ". .env && DATABASE_URL=$TEST_DATABASE_URL vitest",
    "test:e2e": ". .env && DATABASE_URL=$TEST_DATABASE_URL playwright test",
    "test:all": "bun run test && bun run test:e2e",
    "playwright:install": "playwright install",
    "db:seed": "bun run prisma/seed.ts",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:status": "prisma migrate status",
    "db:seed:test": ". .env && DATABASE_URL=$TEST_DATABASE_URL bun prisma/seed-test.ts",
    "db:migrate:test": ". .env && DATABASE_URL=$TEST_DATABASE_URL prisma migrate dev",
    "db:reset:test": ". .env && DATABASE_URL=$TEST_DATABASE_URL prisma migrate reset --force && bun run db:seed:test",
    "db:studio:test": ". .env && DATABASE_URL=$TEST_DATABASE_URL prisma studio",
    "postinstall": "prisma generate"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
