generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id                   String             @id @default(uuid())
  clerkOrganizationId  String?            @map("clerk_organization_id")
  businessName         String             @map("business_name")
  industry             String?
  websiteUrl           String?            @map("website_url")
  subdomain            String?            @unique
  calComUserId         Int?               @map("cal_com_user_id")
  subscriptionActive   Boolean            @default(false) @map("subscription_active")
  subscriptionStatus   String             @default("inactive") @map("subscription_status")
  paddleCustomerId     String?            @unique @map("paddle_customer_id")
  paddleSubscriptionId String?            @unique @map("paddle_subscription_id")
  subscriptionAddons   String[]           @default([]) @map("subscription_addons")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  allowedDomains       String[]           @default([]) @map("allowed_domains")
  isPlatformOwner      Boolean            @default(false) @map("is_platform_owner")
  isReseller           Boolean            @default(false) @map("is_reseller")
  deletedAt            DateTime?          @map("deleted_at")
  clerkUserId          String?            @unique @map("clerk_user_id")
  email                String?            @map("email")
  agentConfig          AgentConfig?
  chatUsages           ChatUsage[]
  conversations        Conversation[]
  emailTemplates       EmailTemplate[]
  leads                Lead[]
  operationalEvents    OperationalEvent[]
  productSpecs         ProductSpec[]
  prospectQueues       ProspectQueue[]
  prospectingConfig    ProspectingConfig?

  @@index([subdomain])
  @@index([isPlatformOwner])
  @@index([deletedAt])
  @@index([clerkUserId])
  @@map("clients")
}

model ProspectingConfig {
  id                String    @id @default(uuid())
  clientId          String    @unique @map("client_id")
  cronEnabled       Boolean   @default(false) @map("cron_enabled")
  searchCriteria    Json?     @map("search_criteria")
  outreachFromEmail String?   @map("outreach_from_email")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  cronDay           Int?      @map("cron_day")
  cronFrequency     String    @default("daily") @map("cron_frequency")
  cronStartDate     DateTime? @map("cron_start_date")
  valueProposition  String?   @map("value_proposition")
  lastCronRunAt     DateTime? @map("last_cron_run_at")
  client            Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("prospecting_configs")
}

model AgentConfig {
  id                  String   @id @default(uuid())
  clientId            String   @unique @map("client_id")
  systemPrompt        String   @map("system_prompt")
  knowledgeBase       Json?    @map("knowledge_base")
  agentName           String?  @map("agent_name")
  greetingMessage     String?  @map("greeting_message")
  widgetPrimaryColour String?  @default("#000000") @map("widget_primary_colour")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  calComUsername      String?  @map("cal_com_username")
  defaultEventSlug    String?  @map("default_event_slug")
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("agent_configs")
}

model Lead {
  id             String         @id @default(uuid())
  clientId       String?        @map("client_id")
  customerName   String?        @map("customer_name")
  email          String?
  phone          String?
  source         LeadSource
  status         LeadStatus     @default(SCRAPED)
  scrapedData    Json?          @map("scraped_data")
  chatTranscript Json?          @map("chat_transcript")
  calBookingUid  String?        @unique @map("cal_booking_uid")
  nextActionDate DateTime?      @map("next_action_date")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  conversations  Conversation[]
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  productSpec    ProductSpec?
  prospectQueue  ProspectQueue?

  @@index([clientId, status])
  @@index([status])
  @@map("leads")
}

model ProspectQueue {
  id            String      @id @default(uuid())
  businessName  String      @map("business_name")
  websiteUrl    String      @map("website_url")
  status        QueueStatus @default(PENDING)
  attempts      Int         @default(0)
  lastAttemptAt DateTime?   @map("last_attempt_at")
  errorMessage  String?     @map("error_message")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  clientId      String?     @map("client_id")
  leadId        String?     @unique @map("lead_id")
  client        Client?     @relation(fields: [clientId], references: [id])
  lead          Lead?       @relation(fields: [leadId], references: [id])

  @@index([clientId, status])
  @@index([status])
  @@map("prospect_queue")
}

model EmailTemplate {
  id        String   @id @default(uuid())
  clientId  String?  @map("client_id")
  name      String
  subject   String
  body      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  client    Client?  @relation(fields: [clientId], references: [id])

  @@index([clientId, isDefault])
  @@map("email_templates")
}

model Conversation {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  leadId    String?  @map("lead_id")
  messages  Json
  sessionId String   @unique @map("session_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead      Lead?    @relation(fields: [leadId], references: [id])

  @@index([clientId])
  @@index([sessionId])
  @@map("conversations")
}

model ProductSpec {
  id                       String            @id @default(uuid())
  leadId                   String            @unique @map("lead_id")
  clientId                 String            @map("client_id")
  stage                    EngagementStage   @default(PENDING)
  profiledNeeds            Json?             @map("profiled_needs")
  prdContent               String?           @map("prd_content")
  engagementObjectives     String?           @map("engagement_objectives")
  buildVariant             String?           @map("build_variant")
  campaignSop              Json?             @map("campaign_sop")
  designConcepts           Json?             @map("design_concepts")
  chosenDesign             Int?              @map("chosen_design")
  githubRepo               String?           @map("github_repo")
  githubIssueUrl           String?           @map("github_issue_url")
  deploymentUrl            String?           @map("deployment_url")
  paddleTransactionId      String?           @map("paddle_transaction_id")
  offerSentAt              DateTime?         @map("offer_sent_at")
  errorMessage             String?           @map("error_message")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  julesLastPolledAt        DateTime?         @map("jules_last_polled_at")
  julesSessionId           String?           @map("jules_session_id")
  julesState               String?           @map("jules_state")
  pullRequestUrl           String?           @map("pull_request_url")
  renderServiceId          String?           @map("render_service_id")
  renderServiceName        String?           @map("render_service_name")
  stageVersion             Int               @default(0) @map("stage_version")
  failedStage              EngagementStage?  @map("failed_stage")
  failedAt                 DateTime?         @map("failed_at")
  failureReason            String?           @map("failure_reason")
  failureSource            String?           @map("failure_source")
  inngestRunId             String?           @map("inngest_run_id")
  inngestRunStatus         String?           @map("inngest_run_status")
  lastReconciledAt         DateTime?         @map("last_reconciled_at")
  lastReconciledBy         String?           @map("last_reconciled_by")
  stitchRunIntentKey       String?           @unique @map("stitch_run_intent_key")
  julesSessionIntentKey    String?           @unique @map("jules_session_intent_key")
  renderServiceIntentKey   String?           @unique @map("render_service_intent_key")
  stitchProjectId          String?           @map("stitch_project_id")
  stitchRunId              String?           @map("stitch_run_id")
  /// Latest Jules activity `progressUpdated.title` (see Activities API).
  julesProgressTitle       String?           @map("jules_progress_title")
  /// Latest Jules activity `progressUpdated.description`.
  julesProgressDescription String?           @map("jules_progress_description")
  client                   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead                     Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stageTransitions         StageTransition[]

  @@index([clientId, stage])
  @@index([leadId])
  @@index([stage, updatedAt])
  @@map("product_specs")
}

model StageTransition {
  id            String           @id @default(uuid())
  productSpecId String           @map("product_spec_id")
  leadId        String           @map("lead_id")
  fromStage     EngagementStage? @map("from_stage")
  toStage       EngagementStage  @map("to_stage")
  source        String
  reason        String?
  inngestRunId  String?          @map("inngest_run_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  productSpec   ProductSpec      @relation(fields: [productSpecId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@map("stage_transitions")
}

model ChatUsage {
  id               String          @id @default(uuid())
  clientId         String          @map("client_id")
  sessionId        String          @map("session_id")
  status           ChatUsageStatus
  denialReason     String?         @map("denial_reason")
  messageCount     Int             @default(0) @map("message_count")
  model            String?
  promptTokens     Int?            @map("prompt_tokens")
  completionTokens Int?            @map("completion_tokens")
  totalTokens      Int?            @map("total_tokens")
  createdAt        DateTime        @default(now()) @map("created_at")
  client           Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@index([status, createdAt])
  @@map("chat_usage")
}

model OperationalEvent {
  id        String                 @id @default(uuid())
  clientId  String?                @map("client_id")
  category  OperationalEventCategory
  eventType String                 @map("event_type")
  status    OperationalEventStatus
  message   String?
  metadata  Json?
  createdAt DateTime               @default(now()) @map("created_at")
  client    Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId, createdAt])
  @@index([category, status, createdAt])
  @@map("operational_events")
}

model WebhookReceipt {
  id                String               @id @default(uuid())
  provider          WebhookProvider
  eventId           String               @map("event_id")
  eventType         String               @map("event_type")
  payload           Json
  signatureVerified Boolean              @default(false) @map("signature_verified")
  status            WebhookReceiptStatus @default(PENDING)
  attempts          Int                  @default(0)
  errorMessage      String?              @map("error_message")
  receivedAt        DateTime             @default(now()) @map("received_at")
  processedAt       DateTime?            @map("processed_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  @@unique([provider, eventId])
  @@index([provider, status, receivedAt])
  @@index([status, receivedAt])
  @@map("webhook_receipts")
}

enum LeadSource {
  INBOUND
  OUTBOUND_PROSPECT
}

enum LeadStatus {
  SCRAPED
  DRAFT_PENDING
  CONTACTED
  REPLIED
  BOOKED
  CLOSED
}

enum QueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum EngagementStage {
  PENDING
  PROFILING
  PROFILED
  WRITING_PRD
  PRD_WRITTEN
  WRITING_STRATEGY
  STRATEGY_COMPLETE
  DESIGNING
  DESIGN_COMPLETE
  BUILDING
  BUILDING_COMPLETE
  DEPLOYING
  DEPLOYED
  OFFER_SENT
  FAILED
}

enum ChatUsageStatus {
  ALLOWED
  DENIED
}

enum OperationalEventCategory {
  CHAT
  WEBHOOK
  AI_USAGE
  SYSTEM
}

enum OperationalEventStatus {
  ALLOWED
  DENIED
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum WebhookProvider {
  CAL
  CLERK
  PADDLE
  VERCEL
}

enum WebhookReceiptStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}
