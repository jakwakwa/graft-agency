# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.claude/worktrees/confident-jang
.clerk
bin
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel
.next/**
# Ignore root-level .md only; keep standard docs and all .md in subdirs
/*.md
!README.md
!vision.md
!LICENSE.md
!CHANGELOG.md
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
!SECURITY.md
!SUPPORT.md

# typescript
*.tsbuildinfo
next-env.d.ts
.DS_Store

/generated/prisma 

# Local Pinggy CLI binaries (see bin/README.md)
/bin/pinggy
/bin/pinggy-macos-arm64
/bin/pinggy-macos-x64
/bin/pinggy-linux-x64
/bin/pinggy-linux-arm64

# clerk configuration (can include secrets)
/.clerk/
.next/server/middleware-build-manifest.js
graft-today-agency.code-workspace
.claude/settings.local.json
.claude/worktrees
