# ─── Local dev: Pinggy tunnel (started automatically with `bun run dev`) ───
# Docs: https://pinggy.io/docs/http_tunnels/ | Stable hostname: https://pinggy.io/docs/persistent_subdomain/
# Put the Pinggy CLI in ./bin/pinggy (see bin/README.md), on your PATH, or set PINGGY_BIN.
PINGGY_TOKEN=
# HTTPS origin of your tunnel, no trailing slash (set once when you have a persistent Pro subdomain).
WEBHOOK_PUBLIC_BASE_URL=https://your-subdomain.a.pinggy.link
PORT=3000
# Optional: run Next only — no Pinggy
# DEV_NO_TUNNEL=true

# Clerk → Graft org sync (Dashboard → Webhooks → `${WEBHOOK_PUBLIC_BASE_URL}/api/webhooks/clerk`)
# Subscribe to: organization.created, organizationMembership.created, organizationMembership.deleted
CLERK_WEBHOOK_SECRET=whsec_...
# Local/dev only: first new organisation becomes the platform client when no platform exists yet
# CLERK_WEBHOOK_BOOTSTRAP_PLATFORM=true

# Chat widget request signing (server-side only). Use a long random value.
WIDGET_TOKEN_SECRET=generate_a_random_widget_token_secret_here

# Engagement Pipeline
# When true, stub/skip Vercel project linking, deploy-side effects, Paddle, and Resend; use with scripts/dry-run-engagement.ts
ENGAGEMENT_DRY_RUN=
# Stitch (design concepts) — https://stitch.withgoogle.com/docs/sdk/ai-sdk/
STITCH_API_KEY=
# Optional: reuse one Stitch project for all engagement runs (else a project is created per run)
# STITCH_PROJECT_ID=

# GitHub (for Jules builds)
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_TEMPLATE_REPO=your-org/prototype-template
GITHUB_BUILDS_ORG=your-org-builds

# Render (service-per-prospect deployment via API — see lib/services/render.service.ts)
# Prospect web services use API plan `free` (Render defaults to paid `starter` if `plan` is omitted).
# Create an API key: Render Dashboard → Account Settings → API Keys.
RENDER_API_KEY=
# Workspace id for service create (GET https://api.render.com/v1/owners with the same API key lists valid ids).
RENDER_OWNER_ID=
# Optional: project environment id (same workspace as RENDER_OWNER_ID). https://api-docs.render.com/reference/list-environments
# RENDER_ENVIRONMENT_ID=
#
# After setting these, new Jules builds: jules-poller runs ensure-render-service-on-pr-branch using the
# GitHub PR head ref (prospect code is on the PR branch before merge). Verify in Inngest → jules-poller →
# successful run steps; on Render, each service should show Branch = PR head and Root = prospects/{slug}.

# Vercel webhook (add this secret in Vercel project settings)
VERCEL_WEBHOOK_SECRET=your_vercel_webhook_secret

# GitHub Actions webhook (shared secret between GH Actions and this app)
GRAFT_WEBHOOK_SECRET=generate_a_random_secret_here

# Paddle (payments) — Merchant of Record, handles global tax/VAT automatically
# Keep this as sandbox for production deployments until go-live.
PADDLE_ENVIRONMENT=sandbox
# API key (server-side only, never expose to client)
PADDLE_API_KEY=your_paddle_api_key
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret
# Client-side token for Paddle.js (safe to expose — used in browser checkout)
# Reusable pricing sections use this token for Paddle.PricePreview() and portal subscription checkout.
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_xxx

# Paddle Sandbox Product/Price IDs (replace with production IDs before go-live)
# Pricing UI reads all product and price IDs below; leave blank only to hide that price from previews.
# Products
PADDLE_PRODUCT_CHATBOT=
PADDLE_PRODUCT_VOICE=
PADDLE_PRODUCT_BOOKING=
PADDLE_PRODUCT_LANDING=
PADDLE_PRODUCT_SMB=
# Subscription prices
PADDLE_PRICE_CHATBOT_MONTHLY= 
PADDLE_PRICE_CHATBOT_ANNUAL=
PADDLE_PRICE_VOICE_MONTHLY=
PADDLE_PRICE_BOOKING_MONTHLY=
# One-time website build prices
PADDLE_PRICE_LANDING=
PADDLE_PRICE_SMB=

# Offer email
OFFER_FROM_EMAIL=hello@graft.today

# Cal.com booking integration
# Use the Cal.com API origin with `/v2`; do not use the web app origin.
CAL_COM_API_KEY=cal_live_or_cal_test_key
CAL_API_BASE=https://api.cal.com/v2
CAL_SLOTS_API_VERSION=2024-09-04
CAL_BOOKINGS_API_VERSION=2026-02-25
# Only needed by tooling that lists event types; chatbot booking uses CAL_USER_USERNAME + CAL_USER_EVENT_SLUG.
CAL_EVENT_TYPES_API_VERSION=2024-06-14
# Platform fallback booking target. Client/platform settings in the database take priority.
CAL_USER_USERNAME=your-cal-username
CAL_USER_EVENT_SLUG=your-event-type-slug
CAL_WEBHOOK_SECRET=your_cal_webhook_secret

# Inngest (GRAFT_INNGEST_EVENT_KEY, GRAFT_INNGEST_SIGNING_KEY in your real .env)
# Local: run `inngest dev` then point the SDK at it (avoids cloud branch env):
# INNGEST_DEV=http://127.0.0.1:8288
# Cloud: set to the **exact** environment name from your Inngest app (wrong name → 404).
# INNGEST_ENV=production
# INNGEST_ENV=production

# ─── Prisma (Postgres) ───
# Main connection (Neon, local Postgres, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Empty database for Migrate shadow applies (`prisma migrate dev`, `migrate diff --from-migrations`).
# Use a separate Neon branch/database or local DB — never point at production data.
# Datadog RUM
NEXT_PUBLIC_DATADOG_ENV=dev
NEXT_PUBLIC_DATADOG_VERSION=1.0.0
